{
  "name": "revstack-os",
  "private": false,
  "license": "SEE LICENSE IN LICENSE.md",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "smoke": "node scripts/smoke-cli.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "turbo run build && changeset publish",
    "test:coverage": "node scripts/test-coverage.mjs",
    "release:dev": "node scripts/release-dev.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@types/node": "^20.11.30",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.2.4",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "turbo": "^2.8.1",
    "typescript": "5.9.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "stripe": "^20.3.1"
  }
}
