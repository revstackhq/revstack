{
  "name": "@revstackhq/providers-core",
  "version": "0.6.0",
  "private": false,
  "license": "FSL-1.1-MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/testing/index.ts --format esm --dts --clean",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@revstackhq/eslint-config": "workspace:*",
    "@types/node": "^20.11.30",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-turbo": "^2.7.1",
    "tsup": "^8.1.0",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.50.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  }
}
